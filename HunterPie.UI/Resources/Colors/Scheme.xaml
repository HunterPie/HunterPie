	<!--  HunterPie  -->
	<LinearGradientBrush x:Key="Brushes.HunterPie.Accent.Horizontal" StartPoint="0,1" EndPoint="1,1">
		<GradientStop Offset="0.863" Color="#FF4B8EEE" />
		<GradientStop Offset="1" Color="#FF10B9DE" />
	</LinearGradientBrush>

	<LinearGradientBrush x:Key="Brushes.HunterPie.Accent.Transparent" StartPoint="0,1" EndPoint="1,1">
		<GradientStop Color="#504B8EEE" />
		<GradientStop Offset="1" Color="#5010B9DE" />
	</LinearGradientBrush>

	<SolidColorBrush x:Key="Brushes.HunterPie.Accent.Solid"
	                 Color="#0d76ef" />
	<SolidColorBrush x:Key="Brushes.HunterPie.Accent.Opacity"
	                 Color="{markup:BrushColor Brush={StaticResource Brushes.HunterPie.Accent.Solid},
	                                           Opacity=0.2}" />

	<SolidColorBrush x:Key="Brushes.HunterPie.Accent"
	                 Color="{markup:BrushColor Brush={StaticResource Brushes.HunterPie.Accent.Solid}}" />

	<SolidColorBrush x:Key="Brushes.HunterPie.Foreground.Primary"
	                 Color="{markup:BrushColor Brush={StaticResource White@100}}" />
	<SolidColorBrush x:Key="Brushes.HunterPie.Foreground.Secondary"
	                 Color="{markup:BrushColor Brush={StaticResource White@300}}" />
	<SolidColorBrush x:Key="Brushes.HunterPie.Foreground.Tertiary"
	                 Color="{markup:BrushColor Brush={StaticResource White@500}}" />
	<SolidColorBrush x:Key="Brushes.HunterPie.Background.Primary"
	                 Color="{markup:BrushColor Brush={StaticResource Gray@100}}" />
	<SolidColorBrush x:Key="Brushes.HunterPie.Background.Secondary"
	                 Color="{markup:BrushColor Brush={StaticResource Gray@200}}" />
	<SolidColorBrush x:Key="Brushes.HunterPie.Background.Tertiary"
	                 Color="{markup:BrushColor Brush={StaticResource Gray@300}}" />
	<SolidColorBrush x:Key="Brushes.HunterPie.Border"
	                 Color="{markup:BrushColor Brush={StaticResource Gray@50}}" />

	<SolidColorBrush x:Key="Brushes.HunterPie.Error"
	                 Color="{markup:BrushColor Brush={StaticResource Red@50}}" />
	<SolidColorBrush x:Key="Brushes.HunterPie.Success"
	                 Color="{markup:BrushColor Brush={StaticResource Green@50}}" />
	<SolidColorBrush x:Key="Brushes.HunterPie.Success.Opacity"
	                 Color="{markup:BrushColor Brush={StaticResource Brushes.HunterPie.Success},
	                                           Opacity=0.2}" />
	<SolidColorBrush x:Key="Brushes.HunterPie.Neutral"
	                 Color="{markup:BrushColor Brush={StaticResource Blue@100}}" />
	<SolidColorBrush x:Key="Brushes.HunterPie.Warning"
	                 Color="{markup:BrushColor Brush={StaticResource Yellow@100}}" />

	<LinearGradientBrush x:Key="Brushes.HunterPie.Tab.Highlight" StartPoint="0,.5" EndPoint="1,1">
		<GradientStop Color="#00000000" />
		<GradientStop Offset="1" Color="{markup:BrushColor Brush={StaticResource Brushes.HunterPie.Accent.Solid}, Opacity=0.1}" />
	</LinearGradientBrush>

	<RadialGradientBrush x:Key="Brushes.HunterPie.Highlight">
		<GradientStop Offset="0" Color="#45FFFFFF" />
		<GradientStop Offset="1" Color="#00000000" />
	</RadialGradientBrush>

	<SolidColorBrush x:Key="Brushes.HunterPie.Ripple">#40F5F5F5</SolidColorBrush>
	<SolidColorBrush x:Key="Brushes.HunterPie.Skeleton.Highlight">#40F5F5F5</SolidColorBrush>

	<SolidColorBrush x:Key="Brushes.Quest.LowRank">#197df0</SolidColorBrush>
	<SolidColorBrush x:Key="Brushes.Quest.HighRank">#EC5D1C</SolidColorBrush>
	<SolidColorBrush x:Key="Brushes.Quest.MasterRank">#F6A522</SolidColorBrush>

	<system:Double x:Key="HunterPie.SideBar.Width">300</system:Double>

	<RadialGradientBrush x:Key="Brushes.Overlay.DesignMode.Background" Center="0.5,0.5" RadiusX="1" RadiusY="1" SpreadMethod="Pad">
		<GradientStop Offset="0" Color="#10D9D9D9" />
		<GradientStop Offset="1" Color="#20D9D9D9" />
	</RadialGradientBrush>

	<LinearGradientBrush x:Key="Brushes.HunterPie.Supporter.Border" StartPoint="0,1" EndPoint="1,1">
		<GradientStop Offset="1" Color="#f89b29" />
		<GradientStop Offset="0" Color="#ff0f7b" />
	</LinearGradientBrush>
	<LinearGradientBrush x:Key="Brushes.HunterPie.Supporter.Background" Opacity="0.3" StartPoint="0,1" EndPoint="1,1">
		<GradientStop Offset="1" Color="#f89b29" />
		<GradientStop Offset="0" Color="#ff0f7b" />
	</LinearGradientBrush>

	<!--  Logging  -->
