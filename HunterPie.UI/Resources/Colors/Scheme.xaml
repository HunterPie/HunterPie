	<SolidColorBrush x:Key="Brushes.HunterPie.Log.Error">#e65e5e</SolidColorBrush>
	<SolidColorBrush x:Key="Brushes.HunterPie.Log.Panic">#ab5ee6</SolidColorBrush>
	<SolidColorBrush x:Key="Brushes.HunterPie.Log.Benchmark">#1BC9B6</SolidColorBrush>

